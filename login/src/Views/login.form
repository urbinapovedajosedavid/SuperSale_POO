    private void btn_Crear_cuentaActionPerformed(java.awt.event.ActionEvent evt) {//GEN-FIRST:event_btn_Crear_cuentaActionPerformed
    // 1. Obtener los textos de todas las variables
        String nombre = txt_name.getText().trim();
        String correo = txt_Correo.getText().trim();      
        String telefono = txt_Telefono.getText().trim();  
        String password = new String(txt_newpass.getPassword()).trim();

        // 2. Validación de campos vacíos
        if (nombre.isEmpty() || correo.isEmpty() || telefono.isEmpty() || password.isEmpty()) {
            javax.swing.JOptionPane.showMessageDialog(this, 
                "Debe de completar los campos primero.", 
                "Campos vacíos", 
                javax.swing.JOptionPane.WARNING_MESSAGE);
            return; 
        }

        // 3. Validación del símbolo '@' en el correo
        if (!correo.contains("@")) {
            javax.swing.JOptionPane.showMessageDialog(this, 
                "El correo electrónico debe incluir el símbolo '@'.", 
                "Formato incorrecto", 
                javax.swing.JOptionPane.ERROR_MESSAGE);
            txt_Correo.requestFocus();
            return; 
        }

        // 4. Validación de solo números en el teléfono
        if (!telefono.matches("\\d+")) { 
            javax.swing.JOptionPane.showMessageDialog(this, 
                "El número de teléfono debe contener solo números.", 
                "Formato incorrecto", 
                javax.swing.JOptionPane.ERROR_MESSAGE);
            txt_Telefono.requestFocus();
            return; 
        }
        
       // Si las validaciones pasan, procedemos a insertar en la BD
    String sql = "INSERT INTO usuarios (nombre, telefono, correo, password) VALUES (?, ?, ?, ?)";

    try (java.sql.Connection con = Data_base.Conexion.conectar();
         java.sql.PreparedStatement pst = con.prepareStatement(sql)) {
        
        // Asignamos los valores de los campos a la consulta
        pst.setString(1, nombre);
        pst.setString(2, telefono);
        pst.setString(3, correo);
        pst.setString(4, password);
        
        // Ejecutamos la inserción
        int filasAfectadas = pst.executeUpdate();
        
        if (filasAfectadas > 0) {
            javax.swing.JOptionPane.showMessageDialog(this, "Usuario registrado exitosamente en la base de datos.");
            
            // Regresar al login
            Views.login ventanaLogin = new Views.login();
            ventanaLogin.setVisible(true);
            this.dispose();
        }
        
    } catch (java.sql.SQLException e) {
        javax.swing.JOptionPane.showMessageDialog(this, "Error al guardar en la base de datos: " + e.getMessage());
        e.printStackTrace();
    }

    }//GEN-LAST:event_btn_Crear_cuentaActionPerformed

